#!/bin/bash
# ClickUp Sync — post-push hook (symlinked into .git/hooks/)
# Resolves agent path dynamically — works regardless of where the repo is cloned.

# Follow the symlink back to the agent directory
HOOK_REAL="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
AGENT_DIR="$(dirname "$HOOK_REAL")"
AGENT_SCRIPT="$AGENT_DIR/agent.mjs"

if [ ! -f "$AGENT_SCRIPT" ]; then
  echo "[clickup-sync] Agent not found at $AGENT_SCRIPT — skipping"
  exit 0
fi

REPO_PATH="$(git rev-parse --show-toplevel)"
BRANCH="$(git rev-parse --abbrev-ref HEAD)"

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    FROM_REF="HEAD~5"
  else
    FROM_REF="$remote_sha"
  fi
  TO_REF="$local_sha"

  echo "[clickup-sync] Syncing $BRANCH ($FROM_REF..$TO_REF)"
  node "$AGENT_SCRIPT" "$REPO_PATH" "$BRANCH" "$FROM_REF" "$TO_REF" &
done

wait
exit 0
